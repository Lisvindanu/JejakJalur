{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "staging-db": {
            "command": "node",
            "args": [
                ".mcp-staging/index.mjs"
            ]
        }
    }
}